---
const { title, description } = Astro.props;
const pageTitle = title ? `${title} — Otwarty Sklep` : 'Otwarty Sklep';
const pageDesc = description || 'Index polskich sklepów internetowych. AI readiness score, schema.org, feedy produktowe.';
---
<!DOCTYPE html>
<html lang="pl" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc}>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
  <style>
    :root {
      --pico-font-size: 17px;
      --pico-line-height: 1.6;
      --pico-spacing: 1.5rem;
      --pico-block-spacing-vertical: 2rem;
      --pico-block-spacing-horizontal: 2rem;
      --pico-nav-element-spacing-vertical: 1.25rem;
      --pico-nav-element-spacing-horizontal: 1rem;
      --pico-typography-spacing-vertical: 1.25rem;
    }
    main.container { padding-top: 2rem; padding-bottom: 3rem; }
    section { margin-bottom: 2.5rem; }
    h1 { margin-bottom: 1.5rem; }
    h2 { margin-top: 2rem; margin-bottom: 1rem; }
    table td, table th { padding: 0.75rem 1rem; }
    hgroup { margin-bottom: 2.5rem; }
    hgroup p { margin-top: 0.5rem; }
    .score-bar { display: flex; gap: 2px; }
    .score-bar span {
      width: 12px; height: 20px;
      background: var(--pico-muted-border-color);
      border-radius: 2px;
    }
    .score-bar span.filled { background: var(--pico-primary); }
    .score-bar span.high { background: #2ecc71; }
    .score-bar span.mid { background: #f39c12; }
    .score-bar span.low { background: #e74c3c; }
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 0.8em;
      background: var(--pico-muted-border-color);
    }
    .badge.yes { background: #d5f5e3; color: #1e8449; }
    .badge.no { background: #fadbd8; color: #922b21; }
    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2.5rem; }
    .stat-card { text-align: center; padding: 1.5rem; }
    .stat-card strong { display: block; font-size: 2.5rem; margin-bottom: 0.25rem; }
    .stat-card p { margin-bottom: 0; }
  </style>
</head>
<body>
  <nav class="container">
    <ul><li><a href="/"><strong>Otwarty Sklep</strong></a></li></ul>
    <ul>
      <li><a href="/">Index</a></li>
    </ul>
  </nav>
  <main class="container">
    <slot />
  </main>
  <footer class="container">
    <small>Otwarty Sklep — agregator dystrybucji do AI agentów zakupowych</small>
  </footer>
</body>
</html>
