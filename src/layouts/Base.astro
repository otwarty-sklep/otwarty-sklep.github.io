---
const { title, description } = Astro.props;
const pageTitle = title ? `${title} — Otwarty Sklep` : 'Otwarty Sklep';
const pageDesc = description || 'Index polskich sklepów internetowych. AI readiness score, schema.org, feedy produktowe.';
---
<!DOCTYPE html>
<html lang="pl" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
  <style>
    :root {
      --pico-font-family: 'Inter', system-ui, -apple-system, sans-serif;
      --pico-font-size: 15px;
      --pico-line-height: 1.6;
      --pico-font-weight: 400;
      --pico-border-radius: 0.5rem;
      --pico-border-width: 1px;

      /* shadcn zinc palette */
      --pico-background-color: hsl(0 0% 100%);
      --pico-color: hsl(240 10% 3.9%);
      --pico-muted-color: hsl(240 3.8% 46.1%);
      --pico-muted-border-color: hsl(240 5.9% 90%);
      --pico-primary: hsl(240 5.9% 10%);
      --pico-primary-hover: hsl(240 5.9% 20%);
      --pico-card-background-color: hsl(0 0% 100%);
      --pico-card-border-color: hsl(240 5.9% 90%);
      --pico-card-sectioning-background-color: hsl(240 4.8% 95.9%);
      --pico-table-border-color: hsl(240 5.9% 90%);
      --pico-table-row-stripped-background-color: hsl(240 4.8% 95.9%);

      /* spacing */
      --pico-spacing: 1.25rem;
      --pico-block-spacing-vertical: 1.5rem;
      --pico-block-spacing-horizontal: 1.5rem;
      --pico-nav-element-spacing-vertical: 1rem;
      --pico-typography-spacing-vertical: 1.25rem;
    }

    /* --- typography: shadcn style --- */
    body {
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      font-optical-sizing: auto;
      font-feature-settings: 'cv01', 'cv02', 'ss01';
    }

    h1 {
      font-size: clamp(1.75rem, 4vw, 2.25rem);
      font-weight: 800;
      letter-spacing: -0.025em;
      line-height: 1.1;
      color: hsl(240 10% 3.9%);
      margin-bottom: 0.5rem;
    }

    h2 {
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1.3;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid hsl(240 5.9% 90%);
    }

    h1 + p, hgroup p {
      font-size: 1rem;
      color: hsl(240 3.8% 46.1%);
      margin-top: 0.25rem;
      line-height: 1.5;
    }

    hgroup { margin-bottom: 2.5rem; }

    /* --- nav: clean top bar --- */
    nav {
      border-bottom: 1px solid hsl(240 5.9% 90%);
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
    }
    nav a { font-size: 0.875rem; letter-spacing: -0.01em; }
    nav strong { font-weight: 700; letter-spacing: -0.02em; font-size: 0.9rem; }

    /* --- main --- */
    main { padding-top: 2.5rem; padding-bottom: 4rem; }

    /* --- sections --- */
    section { margin-bottom: 2rem; }

    /* --- table: tight, clean --- */
    table { font-size: 0.875rem; }
    th {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: hsl(240 3.8% 46.1%);
    }
    td, th { padding: 0.75rem 1rem; }
    td a { font-weight: 500; }

    /* --- article/card: shadcn card --- */
    article {
      border: 1px solid hsl(240 5.9% 90%);
      border-radius: 0.75rem;
      box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
      padding: 1.5rem;
    }

    /* --- footer --- */
    body > footer {
      border-top: 1px solid hsl(240 5.9% 90%);
      padding-top: 1.5rem;
      margin-top: 2rem;
    }
    body > footer small { color: hsl(240 3.8% 46.1%); font-size: 0.8rem; }

    /* --- links --- */
    a { color: hsl(240 5.9% 10%); text-decoration-thickness: 1px; text-underline-offset: 3px; }
    a:hover { color: hsl(240 5.9% 30%); }

    /* --- mark --- */
    mark {
      background: transparent;
      background-image: linear-gradient(120deg, hsl(50 100% 80%) 0%, hsl(50 100% 70%) 100%);
      background-repeat: no-repeat;
      background-size: 100% 40%;
      background-position: 0 85%;
      padding: 0 2px;
      color: inherit;
    }

    /* --- stat grid (uses article) --- */
    section[data-grid] {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
    section[data-grid] article {
      text-align: center;
      padding: 1.25rem 1rem;
    }
    section[data-grid] article strong {
      display: block;
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.025em;
      line-height: 1;
      margin-bottom: 0.25rem;
      color: hsl(240 10% 3.9%);
      font-variant-numeric: lining-nums tabular-nums;
    }
    section[data-grid] article p {
      margin: 0;
      font-size: 0.8rem;
      color: hsl(240 3.8% 46.1%);
    }

    /* --- score bar (data attrs) --- */
    [data-score] { display: flex; gap: 3px; }
    [data-score] span {
      width: 14px; height: 22px;
      background: hsl(240 5.9% 90%);
      border-radius: 3px;
    }
    [data-score] span[data-fill="high"] { background: hsl(142 71% 45%); }
    [data-score] span[data-fill="mid"] { background: hsl(38 92% 50%); }
    [data-score] span[data-fill="low"] { background: hsl(0 84% 60%); }

    /* --- badges (data attrs) --- */
    [data-badge] {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.01em;
    }
    [data-badge="yes"] { background: hsl(142 76% 94%); color: hsl(142 71% 29%); }
    [data-badge="no"] { background: hsl(0 93% 94%); color: hsl(0 84% 35%); }

    /* --- ul inside section: recommendation list --- */
    section > ul { padding-left: 1.25rem; }
    section > ul li { margin-bottom: 0.75rem; font-size: 0.9rem; }

    @media (max-width: 520px) {
      section[data-grid] { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>
  <nav class="container">
    <ul><li><a href="/"><strong>Otwarty Sklep</strong></a></li></ul>
    <ul>
      <li><a href="/">Index</a></li>
    </ul>
  </nav>
  <main class="container">
    <slot />
  </main>
  <footer class="container">
    <small>Otwarty Sklep — agregator dystrybucji do AI agentów zakupowych</small>
  </footer>
</body>
</html>
