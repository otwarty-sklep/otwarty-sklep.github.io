---
import { readFileSync } from 'fs';
import { resolve } from 'path';

const critical = readFileSync(resolve(import.meta.dirname, '../../public/os.critical.css'), 'utf-8');

const { title, description } = Astro.props;
const pageTitle = title ? `${title} — Otwarty Sklep` : 'Otwarty Sklep';
const pageDesc = description || 'Index polskich sklepów internetowych. AI readiness score, schema.org, feedy produktowe.';
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc}>
  <style set:html={critical}></style>
  <link rel="preload" href="/os.defer.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/os.defer.css"></noscript>
</head>
<body>
  <nav class="container">
    <ul><li><a href="/"><strong>Otwarty Sklep</strong></a></li></ul>
    <ul>
      <li><a href="/">Index</a></li>
    </ul>
  </nav>
  <main class="container">
    <slot />
  </main>
  <footer class="container">
    <small>Otwarty Sklep — agregator dystrybucji do AI agentów zakupowych</small>
  </footer>
</body>
</html>
