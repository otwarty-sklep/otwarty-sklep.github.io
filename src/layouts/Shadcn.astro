---
// Shadcn layout — dashboard, 1100px, .container
import { readFileSync } from 'fs';
import { resolve } from 'path';
const css = readFileSync(resolve(import.meta.dirname, '../../public/shadcn.css'), 'utf-8');

const { title, description } = Astro.props;
const pageTitle = title ? `${title} — Otwarty Sklep` : 'Otwarty Sklep';
const pageDesc = description || 'Index polskich sklepów internetowych. AI readiness.';
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc}>
  <style set:html={css}></style>
</head>
<body>
  <nav class="container">
    <ul><li><a href="/"><strong>Otwarty Sklep</strong></a></li></ul>
    <ul><li><a href="/index-sklepow/">Index sklepów</a></li></ul>
  </nav>
  <main class="container">
    <slot />
  </main>
  <footer class="container">
    <small>Otwarty Sklep — darmowy sklep internetowy w 10 minut</small>
  </footer>
</body>
</html>
