---
import Shadcn from '../layouts/Shadcn.astro';
import StatGrid from '../themes/shadcn/StatGrid.astro';
import ScoreBar from '../themes/shadcn/ScoreBar.astro';
import Badge from '../themes/shadcn/Badge.astro';
import { getStats, loadShops } from '../data/shops.js';

const stats = await getStats();
const shops = await loadShops();
const topShops = shops.filter(s => s.score >= 6).sort((a, b) => b.score - a.score).slice(0, 20);
---
<Shadcn title="Index polskich sklepów">
  <hgroup>
    <h1>Index polskich sklepów</h1>
    <p>{stats.total.toLocaleString('pl')} sklepów przeskanowanych pod kątem AI readiness</p>
  </hgroup>

  <StatGrid items={[
    {value: stats.total.toLocaleString('pl'), label: 'sklepów'},
    {value: stats.withSchema.toLocaleString('pl'), label: `ze schema.org (${Math.round(stats.withSchema / stats.total * 100)}%)`},
    {value: stats.withSitemap.toLocaleString('pl'), label: `z sitemap (${Math.round(stats.withSitemap / stats.total * 100)}%)`},
    {value: stats.withFeed.toLocaleString('pl'), label: `z feedem (${Math.round(stats.withFeed / stats.total * 100)}%)`},
  ]} />

  <h2>Top sklepy (score ≥ 6)</h2>
  <figure>
    <table>
      <thead>
        <tr>
          <th>Domena</th>
          <th>Platforma</th>
          <th>Score</th>
          <th>Schema.org</th>
          <th>Sitemap</th>
          <th>Feed</th>
        </tr>
      </thead>
      <tbody>
        {topShops.map(s => (
          <tr>
            <td><a href={`/sklep/${s.domain}/`}>{s.domain}</a></td>
            <td>{s.platform || '—'}</td>
            <td><ScoreBar score={s.score} /></td>
            <td><Badge variant={s.schema_org ? 'yes' : 'no'}>{s.schema_org ? 'tak' : 'nie'}</Badge></td>
            <td><Badge variant={s.resources?.sitemap ? 'yes' : 'no'}>{s.resources?.sitemap ? 'tak' : 'nie'}</Badge></td>
            <td><Badge variant={s.resources?.feed ? 'yes' : 'no'}>{s.resources?.feed ? 'tak' : 'nie'}</Badge></td>
          </tr>
        ))}
      </tbody>
    </table>
  </figure>
</Shadcn>
