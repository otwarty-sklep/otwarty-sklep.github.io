---
import Shadcn from '../../layouts/Shadcn.astro';
import { loadShops } from '../../data/shops.js';

export async function getStaticPaths() {
  const shops = await loadShops();
  const sorted = shops.sort((a, b) => b.score - a.score);
  return sorted.slice(0, 1).map(s => ({
    params: { domain: s.domain },
    props: { shop: s },
  }));
}

const { shop } = Astro.props;
const maxScore = 14;
const pct = Math.round((shop.score / maxScore) * 100);
---
<Shadcn title={shop.domain} description={`AI readiness score: ${shop.score}/${maxScore} dla ${shop.domain}`}>
  <hgroup>
    <h1>{shop.domain}</h1>
    <p>AI readiness: {shop.score}/{maxScore} punktów ({pct}%)</p>
  </hgroup>

  <section>
    <h2>Score</h2>
    <div data-score style="gap: 4px;">
      {Array.from({length: maxScore}, (_, i) => {
        const filled = i < shop.score;
        const fill = filled ? (shop.score >= 8 ? 'high' : shop.score >= 5 ? 'mid' : 'low') : undefined;
        return <span data-fill={fill} style="width: 24px; height: 32px;"></span>;
      })}
    </div>
  </section>

  <section>
    <h2>Metryki</h2>
    <table>
      <tbody>
        <tr><td>Platforma</td><td><strong>{shop.platform || 'nierozpoznana'}</strong></td></tr>
        <tr><td>Schema.org</td><td><span data-badge={shop.schema_org ? 'yes' : 'no'}>{shop.schema_org ? 'Tak' : 'Brak'}</span></td></tr>
        <tr><td>JSON-LD Product</td><td><span data-badge={shop.jsonld_product ? 'yes' : 'no'}>{shop.jsonld_product ? 'Tak' : 'Brak'}</span></td></tr>
        <tr><td>Sitemap</td><td>{shop.resources?.sitemap ? <a href={shop.resources.sitemap} target="_blank">{shop.resources.sitemap}</a> : <span data-badge="no">Brak</span>}</td></tr>
        <tr><td>Feed</td><td>{shop.resources?.feed ? <a href={shop.resources.feed} target="_blank">{shop.resources.feed}</a> : <span data-badge="no">Brak</span>}</td></tr>
        <tr><td>UCP</td><td>{shop.resources?.ucp ? <a href={shop.resources.ucp} target="_blank">{shop.resources.ucp}</a> : <span data-badge="no">Brak</span>}</td></tr>
      </tbody>
    </table>
  </section>

  {shop.robots && (
    <section>
      <h2>Boty AI</h2>
      <table>
        <thead><tr><th>Bot</th><th>Status</th></tr></thead>
        <tbody>
          {Object.entries(shop.robots).map(([bot, status]) => (
            <tr><td>{bot}</td><td><span data-badge={status === 'allow' ? 'yes' : 'no'}>{status}</span></td></tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <section>
    <h2>Rekomendacje</h2>
    <ul>
      {!shop.schema_org && <li><strong>Dodać schema.org/Product</strong> — bez tego ChatGPT i Perplexity nie widzą produktów.</li>}
      {!shop.jsonld_product && shop.schema_org && <li><strong>Dodać JSON-LD Product</strong> — ma schema.org ale brakuje typu Product.</li>}
      {!shop.resources?.sitemap && <li><strong>Dodać sitemap.xml</strong> — crawlery AI nie wiedzą jakie strony istnieją.</li>}
      {!shop.resources?.feed && <li><strong>Wygenerować feed produktowy</strong> — wymagany do Google Merchant Center.</li>}
      {shop.score >= 6 && <li><strong>Google Merchant Center</strong> — ma wystarczające dane żeby aplikować.</li>}
    </ul>
  </section>
</Shadcn>
