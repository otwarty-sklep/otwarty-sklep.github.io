---
import Swiss from '../../../layouts/Swiss.astro';
import Steps from '../../../themes/swiss/Steps.astro';
import StatGrid from '../../../themes/swiss/StatGrid.astro';
---
<Swiss title="Sprzedawaj przez AI agentów" description="Masz produkty ale nie masz platformy? Wystawimy Twoje produkty w Von Halsky, ChatGPT i Google AI.">

  <nav>
    <strong>Otwarty Sklep</strong>
    <a href="/landing/">Dla sprzedawców</a>
  </nav>

  <h1>Sprzedawaj przez <mark>AI agentów</mark></h1>

  <p>Masz produkty ale nie masz platformy? Daj nam katalog — wystawimy Twoje produkty w Von Halsky, ChatGPT i Google AI. <mark>Bez Shopera, bez Base, bez abonamentów</mark>.</p>

  <Steps items={[
    {num: "01", text: "Daj nam listę produktów — zdjęcia, ceny, opisy. <mark>Resztą zajmiemy się my</mark>"},
    {num: "02", text: "Twoje produkty trafią do <mark>16 mln klientów InPostu</mark> i AI agentów zakupowych"},
    {num: "03", text: "Nie potrzebujesz platformy. Nie płacisz abonamentu. <mark>Zero kosztów wejścia</mark>"},
  ]} />

  <fieldset>
    <legend>Zostaw email — odezwiemy się w 48h</legend>
    <form action="https://formspree.io/f/TWOJ_ID" method="POST">
      <input type="hidden" name="_landing" value="B-marketplace">
      <input type="email" name="email" placeholder="twoj@email.pl" required>
      <button type="submit">Chcę sprzedawać</button>
    </form>
    <small>Bez spamu. Odpisujemy osobiście.</small>
  </fieldset>

  <table>
    <tr><th></th><th>Otwarty Sklep</th><th>Shoper</th><th>Base</th></tr>
    <tr><td>Koszt wejścia</td><td><strong>0 zł</strong></td><td>od 100 zł/mies.</td><td>od $39/mies.</td></tr>
    <tr><td>Von Halsky</td><td><strong>W pakiecie</strong></td><td>Osobno</td><td>Osobno</td></tr>
    <tr><td>ChatGPT + Google AI</td><td><strong>W pakiecie</strong></td><td>Brak</td><td>Brak</td></tr>
    <tr><td>Czas startu</td><td><strong>24h</strong></td><td>Dni</td><td>Dni</td></tr>
  </table>

  <StatGrid items={[
    {value: "50 mln", label: "zapytań zakupowych dziennie w ChatGPT"},
    {value: "16 mln", label: "klientów InPostu w apce"},
  ]} />

</Swiss>
