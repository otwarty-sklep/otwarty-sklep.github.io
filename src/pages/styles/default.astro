---
import { readFileSync } from 'fs';
import { resolve } from 'path';
const css = readFileSync(resolve(import.meta.dirname, '../../../public/os.css'), 'utf-8');
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>default (os.css) — Otwarty Sklep Style</title>
  <style set:html={css}></style>
</head>
<body>

  <nav class="container">
    <ul><li><a href="/"><strong>default.css</strong></a></li></ul>
    <ul>
      <li><a href="/styles/swiss/">swiss.css</a></li>
    </ul>
  </nav>

  <main class="container">

    <hgroup>
      <h1>Default — os.css</h1>
      <p>Styl dashboardowy. Szeroka kolumna, karty, tabele, score-bary, badges. Dla danych i paneli.</p>
    </hgroup>

    <h2>Stat Grid</h2>

    <section data-grid>
      <article>
        <strong>23 194</strong>
        <p>sklepów</p>
      </article>
      <article>
        <strong>43%</strong>
        <p>ze schema.org</p>
      </article>
      <article>
        <strong>51%</strong>
        <p>z sitemap</p>
      </article>
      <article>
        <strong>12%</strong>
        <p>z feedem</p>
      </article>
    </section>

    <h2>Typografia</h2>

    <h1>Heading 1 — 800, ciasny tracking</h1>
    <h2>Heading 2 — z dolną linią</h2>
    <h3>Heading 3 — kompaktowy</h3>

    <p>Paragraf z <strong>boldem</strong>, <em>kursywą</em>, <mark>markerem</mark>, <a href="#">linkiem</a>, <code>kodem inline</code> i <small>małym tekstem</small>.</p>

    <hgroup>
      <h1>Hgroup — tytuł z opisem</h1>
      <p>Opis pod tytułem — muted kolor, mniejszy font, brak dolnego marginesu.</p>
    </hgroup>

    <h2>Columns — data-cols</h2>

    <section data-cols="2">
      <article>
        <h3>Kolumna 1</h3>
        <p>Dwie kolumny przez <code>data-cols="2"</code>.</p>
      </article>
      <article>
        <h3>Kolumna 2</h3>
        <p>RWD: stackują się na mobile.</p>
      </article>
    </section>

    <section data-cols="3">
      <article>
        <h3>Col 1</h3>
        <p>Trzy kolumny.</p>
      </article>
      <article>
        <h3>Col 2</h3>
        <p>Automatyczny grid.</p>
      </article>
      <article>
        <h3>Col 3</h3>
        <p>Responsywne.</p>
      </article>
    </section>

    <h2>Tabela</h2>

    <figure>
      <table>
        <thead>
          <tr>
            <th>Domena</th>
            <th>Platforma</th>
            <th>Score</th>
            <th>Schema</th>
            <th>Feed</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><a href="#">example-shop.pl</a></td>
            <td>woocommerce</td>
            <td>
              <div data-score>
                <span data-fill="high"></span><span data-fill="high"></span><span data-fill="high"></span>
                <span data-fill="high"></span><span data-fill="high"></span><span data-fill="high"></span>
                <span data-fill="high"></span><span data-fill="high"></span><span data-fill="high"></span>
                <span data-fill="high"></span><span></span><span></span><span></span><span></span>
              </div>
            </td>
            <td><span data-badge="yes">tak</span></td>
            <td><span data-badge="yes">tak</span></td>
          </tr>
          <tr>
            <td><a href="#">sklep-test.pl</a></td>
            <td>prestashop</td>
            <td>
              <div data-score>
                <span data-fill="mid"></span><span data-fill="mid"></span><span data-fill="mid"></span>
                <span data-fill="mid"></span><span data-fill="mid"></span><span data-fill="mid"></span>
                <span></span><span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span>
              </div>
            </td>
            <td><span data-badge="yes">tak</span></td>
            <td><span data-badge="no">nie</span></td>
          </tr>
          <tr>
            <td><a href="#">nowy-sklep.pl</a></td>
            <td>—</td>
            <td>
              <div data-score>
                <span data-fill="low"></span><span data-fill="low"></span><span data-fill="low"></span>
                <span></span><span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
              </div>
            </td>
            <td><span data-badge="no">nie</span></td>
            <td><span data-badge="no">nie</span></td>
          </tr>
        </tbody>
      </table>
    </figure>

    <h2>Score Bar</h2>

    <p>High (≥8):</p>
    <div data-score>
      <span data-fill="high"></span><span data-fill="high"></span><span data-fill="high"></span>
      <span data-fill="high"></span><span data-fill="high"></span><span data-fill="high"></span>
      <span data-fill="high"></span><span data-fill="high"></span><span data-fill="high"></span>
      <span data-fill="high"></span><span></span><span></span><span></span><span></span>
    </div>
    <p>Mid (5-7):</p>
    <div data-score>
      <span data-fill="mid"></span><span data-fill="mid"></span><span data-fill="mid"></span>
      <span data-fill="mid"></span><span data-fill="mid"></span><span data-fill="mid"></span>
      <span></span><span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span>
    </div>
    <p>Low (&lt;5):</p>
    <div data-score>
      <span data-fill="low"></span><span data-fill="low"></span><span data-fill="low"></span>
      <span></span><span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
    </div>

    <h2>Badges</h2>

    <p>
      <span data-badge="yes">tak</span>
      <span data-badge="no">nie</span>
    </p>

    <h2>Article / Card</h2>

    <article>
      <h3>Karta</h3>
      <p>Border, radius, subtle shadow. Czysty <code>&lt;article&gt;</code>.</p>
    </article>

    <h2>Lists</h2>

    <ul>
      <li>Element nieuporządkowany</li>
      <li>Z <strong>boldem</strong> i <a href="#">linkiem</a></li>
    </ul>

    <ol>
      <li>Krok pierwszy</li>
      <li>Krok drugi</li>
    </ol>

    <h2>Code</h2>

    <p>Inline: <code>&lt;link rel="stylesheet" href="/os.css"&gt;</code></p>

    <h2>Misc</h2>

    <hr>
    <p><code>&lt;hr&gt;</code> — separator sekcji.</p>
    <p><code>&lt;mark&gt;</code> — <mark>podświetlony tekst</mark>.</p>
    <p><code>&lt;small&gt;</code> — <small>mały muted tekst.</small></p>

  </main>

  <footer class="container">
    <small><a href="/">Otwarty Sklep</a> · <a href="/styles/swiss/">swiss.css</a> · <a href="https://github.com/otwarty-sklep">GitHub</a></small>
  </footer>

</body>
</html>
