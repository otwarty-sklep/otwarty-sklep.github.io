{
  "name": "shadcn",
  "description": "Dashboard / data-heavy style. Karty z cieniem i zaokrągleniem, ciasna typografia, szeroki layout (1100px). Dla: rankingów, listingów, dashboardów, paneli danych.",
  "layout": "Shadcn.astro",
  "base_css": "shadcn.css",
  "max_width": "1100px",
  "components": {
    "Card": {
      "file": "Card.astro",
      "description": "Kontener z obramowaniem, cieniem i border-radius 0.75rem",
      "props": {
        "title": { "type": "string", "required": false, "description": "Opcjonalny nagłówek karty" }
      },
      "slots": { "default": "Zawartość karty (dowolny HTML)" },
      "example": "<Card title=\"Metryki\">\n  <p>Treść karty</p>\n</Card>"
    },
    "Badge": {
      "file": "Badge.astro",
      "description": "Pill z kolorem — status tak/nie, zielony/czerwony lub neutralny",
      "props": {
        "variant": { "type": "yes|no|green|red", "required": false, "description": "Kolor badge'a. Bez wariantu = neutralny szary" },
        "label": { "type": "string", "required": false, "description": "Tekst. Alternatywa dla slot" }
      },
      "slots": { "default": "Tekst badge'a (zamiast prop label)" },
      "example": "<Badge variant=\"yes\">Tak</Badge>\n<Badge variant=\"no\" label=\"Brak\" />"
    },
    "ScoreBar": {
      "file": "ScoreBar.astro",
      "description": "Wizualna belka punktacji — kolorowe prostokąty od 0 do max",
      "props": {
        "score": { "type": "number", "required": true, "description": "Aktualny wynik" },
        "max": { "type": "number", "required": false, "default": 14, "description": "Maksymalny wynik" },
        "size": { "type": "sm|md", "required": false, "default": "sm", "description": "Rozmiar belki" }
      },
      "example": "<ScoreBar score={8} />\n<ScoreBar score={12} max={14} size=\"md\" />"
    },
    "StatGrid": {
      "file": "StatGrid.astro",
      "description": "Grid kart z dużymi liczbami — statystyki dashboard",
      "props": {
        "items": { "type": "Array<{value: string, label: string}>", "required": true, "description": "Lista statystyk do wyświetlenia" }
      },
      "example": "<StatGrid items={[\n  {value: \"25 765\", label: \"sklepów\"},\n  {value: \"43%\", label: \"ze schema.org\"}\n]} />"
    }
  }
}
