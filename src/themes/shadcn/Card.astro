---
/**
 * Card — kontener z obramowaniem, cieniem i zaokrągleniem
 * @prop {string} title - opcjonalny nagłówek karty
 */
const { title } = Astro.props;
---
<article class="card">
  {title && <h3>{title}</h3>}
  <slot />
</article>

<style>
  .card {
    background: var(--card-bg, #fff);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    box-shadow: var(--card-shadow, 0 1px 3px 0 rgb(0 0 0 / 0.06));
    padding: 1.5rem;
    margin-bottom: 1rem;
  }
  h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 620;
    letter-spacing: -0.02em;
  }
</style>
