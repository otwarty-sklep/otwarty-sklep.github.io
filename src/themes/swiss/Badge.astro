---
/**
 * Badge — pill z kolorem yes/no/green/red lub neutralny (styl Swiss)
 * @prop {"yes"|"no"|"green"|"red"} variant - wariant kolorystyczny
 * @prop {string} label - tekst badge'a (alternatywa dla slot)
 */
const { variant, label } = Astro.props;
---
<span class:list={["badge", variant]}>
  {label ?? <slot />}
</span>

<style>
  .badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 500;
    background: var(--surface, hsl(240 4.8% 95.9%));
    color: var(--fg-muted, hsl(240 3.8% 46.1%));
  }
  .yes, .green { background: hsl(142 76% 94%); color: hsl(142 71% 29%); }
  .no, .red    { background: hsl(0 93% 94%); color: hsl(0 84% 35%); }

  @media(prefers-color-scheme:dark) {
    :global(:root:not([data-theme="light"])) .yes,
    :global(:root:not([data-theme="light"])) .green { background: hsl(142 40% 14%); color: hsl(142 71% 65%); }
    :global(:root:not([data-theme="light"])) .no,
    :global(:root:not([data-theme="light"])) .red   { background: hsl(0 50% 14%); color: hsl(0 84% 70%); }
  }
  :global([data-theme="dark"]) .yes, :global([data-theme="dark"]) .green { background: hsl(142 40% 14%); color: hsl(142 71% 65%); }
  :global([data-theme="dark"]) .no, :global([data-theme="dark"]) .red   { background: hsl(0 50% 14%); color: hsl(0 84% 70%); }
</style>
